# ─────────────────────────────────────────────────────────────
# SELLO Environment Configuration
# ─────────────────────────────────────────────────────────────

# App
APP_NAME=SELLO
APP_ENV=development
DEBUG=true
SECRET_KEY=secret_key_32_chars_minimum_sello_app_secret
API_VERSION=v1

# Database (connects to postgres service inside Docker)
POSTGRES_USER=sello
POSTGRES_PASSWORD=sello_secret
POSTGRES_DB=sello_db
DATABASE_URL=postgresql+asyncpg://sello:sello_secret@postgres:5432/sello_db

# Redis (connects to redis service inside Docker)
REDIS_PASSWORD=redis_secret
REDIS_URL=redis://:redis_secret@redis:6379/0

# Qdrant (connects to qdrant service inside Docker)
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION_LEADS=sello_leads
QDRANT_COLLECTION_MEMORY=sello_memory

# Ollama (connects to ollama service inside Docker)
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_DEFAULT_MODEL=qwen2.5:7b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# JWT Auth
JWT_SECRET_KEY=sello_secret_jwt_generation_key_value
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# CORS
FRONTEND_URL=http://localhost:3000

# Platform Connectors
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=SELLO/1.0
TWITTER_BEARER_TOKEN=
GITHUB_TOKEN=
DISCORD_BOT_TOKEN=

# Notifications
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SLACK_WEBHOOK_URL=
DISCORD_WEBHOOK_URL=

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000
