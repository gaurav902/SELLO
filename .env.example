# ─────────────────────────────────────────────────────────────
# SELLO Environment Configuration
# Copy to .env and fill in your values
# ─────────────────────────────────────────────────────────────

# App
APP_NAME=SELLO
APP_ENV=development
DEBUG=true
SECRET_KEY=change_me_to_a_long_random_secret_key_min_32_chars
API_VERSION=v1

# Database
POSTGRES_USER=sello
POSTGRES_PASSWORD=sello_secret
POSTGRES_DB=sello_db
DATABASE_URL=postgresql+asyncpg://sello:sello_secret@localhost:5432/sello_db

# Redis
REDIS_PASSWORD=redis_secret
REDIS_URL=redis://:redis_secret@localhost:6379/0

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION_LEADS=sello_leads
QDRANT_COLLECTION_MEMORY=sello_memory

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=qwen2.5:7b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# JWT Auth
JWT_SECRET_KEY=change_me_jwt_secret_key
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# CORS
FRONTEND_URL=http://localhost:3000

# Platform Connectors (fill when available)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=SELLO/1.0
TWITTER_BEARER_TOKEN=
GITHUB_TOKEN=
DISCORD_BOT_TOKEN=

# Notifications
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SLACK_WEBHOOK_URL=
DISCORD_WEBHOOK_URL=

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000
